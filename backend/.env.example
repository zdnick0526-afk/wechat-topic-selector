# ============================================
# Application Configuration
# ============================================
APP_NAME=WeChat Topic Selector
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# API Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Frontend
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:8000"]

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/wechat_topics
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# Cache Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
SESSION_TTL=86400

# ============================================
# Data Collection Configuration
# ============================================
WEIBO_ENABLED=true
WEIBO_UPDATE_INTERVAL=900
WEIBO_API_KEY=your_weibo_api_key

ZHIHU_ENABLED=true
ZHIHU_UPDATE_INTERVAL=900

DOUYIN_ENABLED=true
DOUYIN_UPDATE_INTERVAL=1800

XIAOHONGSHU_ENABLED=true
XIAOHONGSHU_UPDATE_INTERVAL=1800

BAIDU_ENABLED=true
BAIDU_UPDATE_INTERVAL=3600

NEWS_ENABLED=true
NEWS_UPDATE_INTERVAL=3600

# ============================================
# NLP Configuration
# ============================================
MAX_KEYWORDS=10
MIN_KEYWORD_LENGTH=2
KEYWORD_THRESHOLD=0.3

# ============================================
# ML Configuration
# ============================================
ML_MODEL_PATH=/models
MODEL_UPDATE_INTERVAL=86400
PREDICTION_CONFIDENCE_THRESHOLD=0.6

# ============================================
# Recommendation Configuration
# ============================================
RECOMMENDATION_TOP_K=10
COLLABORATIVE_WEIGHT=0.4
CONTENT_WEIGHT=0.3
TRENDING_WEIGHT=0.3

# ============================================
# Security Configuration
# ============================================
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Feature Flags
# ============================================
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_COMPETITOR_ANALYSIS=true
FEATURE_SENTIMENT_ANALYSIS=true
FEATURE_TREND_PREDICTION=true
FEATURE_CONTENT_CALENDAR=true